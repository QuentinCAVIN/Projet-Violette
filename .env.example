# Exemple de variables d'environnement pour docker-compose
# Copier ce fichier en .env et adapter les valeurs si nécessaire.
# Les valeurs ci-dessous sont les défauts utilisés en développement local.

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=violette_db
DB_USERNAME=violette
DB_PASSWORD=violette
MYSQL_ROOT_PASSWORD=root

# Firebase (requis uniquement avec le profil "firebase" du backend)
# FIREBASE_PROJECT_ID=votre-projet-firebase
